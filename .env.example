# Runtime settings
AGENT_DB_PATH=./runtime.db
AGENT_LOG_LEVEL=INFO
AGENT_WEBHOOKS_HOST=127.0.0.1
AGENT_WEBHOOKS_PORT=8001

# LLM provider
# Supported values: null, fake, minimax
AGENT_LLM_PROVIDER=null

# FakeLLM settings
AGENT_FAKE_LLM_RESPONSE_JSON={"summary":"fake summary","severity":"low","next_action":"retry"}
AGENT_FAKE_LLM_MODEL=fake-llm

# MiniMax settings
AGENT_MINIMAX_API_KEY=
AGENT_MINIMAX_BASE_URL=https://api.minimax.io/v1
AGENT_MINIMAX_MODEL=MiniMax-M2.5
AGENT_MINIMAX_TIMEOUT_SECONDS=30

# GitHub MCP settings
# Used by skills/release_skiller.yaml
AGENT_GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/
AGENT_GITHUB_MCP_TOKEN=

# MCP server endpoint (option 1: remote HTTP/streamable)
AGENT_MCP_LOCAL_MCP_URL=http://127.0.0.1:7800/mcp
# AGENT_MCP_GIT_URL=http://127.0.0.1:7900/mcp

# Optional Git MCP stdio mode (used by create_release skill)
# AGENT_MCP_GIT_COMMAND=/home/fede/develop/py/mcp/.venv/bin/python
# AGENT_MCP_GIT_ARGS=["/home/fede/develop/py/mcp/git_mcp.py"]
# AGENT_MCP_GIT_ENV={}
# AGENT_MCP_GIT_CWD=/home/fede/develop/py/mcp

# MCP server local spawn (recommended): autostart HTTP process by skiller runtime
# AGENT_MCP_LOCAL_MCP_AUTOSTART_COMMAND=/home/fede/develop/py/mcp/.venv/bin/python
# AGENT_MCP_LOCAL_MCP_AUTOSTART_ARGS=["/home/fede/develop/py/mcp/local_mcp.py"]
# AGENT_MCP_LOCAL_MCP_AUTOSTART_ENV={}
# AGENT_MCP_LOCAL_MCP_AUTOSTART_CWD=/home/fede/develop/py/mcp
# AGENT_MCP_LOCAL_MCP_AUTOSTART_TIMEOUT=10

# MCP server local spawn (option 3: stdio client mode)
# AGENT_MCP_LOCAL_MCP_COMMAND=/home/fede/develop/py/mcp/.venv/bin/python
# AGENT_MCP_LOCAL_MCP_ARGS=["/home/fede/develop/py/mcp/local_mcp.py"]
# AGENT_MCP_LOCAL_MCP_ENV={}
# AGENT_MCP_LOCAL_MCP_CWD=/home/fede/develop/py/mcp
