{
  "llm": {
    "default_provider": "minimax-main",
    "providers": {
      "minimax-main": {
        "provider": "minimax",
        "client_type": "openai_chat_completions",
        "api_key_file": "~/.skiller/secrets/minimax_api_key",
        "base_url": "https://api.minimax.io/v1",
        "model": "MiniMax-M2.5",
        "timeout_seconds": 30,
        "context_window_tokens": 1000000
      }
    }
  },
  "loop": {
    "max_turns": 10,
    "max_tool_calls": 8
  },
  "tools": {
    "shell": {
      "workspace": ".",
      "allowlist_enabled": true,
      "allow_env_prefix": true,
      "allowed_commands": [
        "pwd",
        "ls",
        "find",
        "rg",
        "grep",
        "head",
        "tail",
        "wc",
        "nl",
        "cat",
        "git",
        "ruff",
        "pytest",
        "uv",
        "python",
        "python3",
        "skiller",
        "date"
      ]
    },
    "files": {
      "read": [
        ".",
        "~/.skiller/settings/"
      ],
      "write": [
        "."
      ],
      "all": []
    }
  }
}
