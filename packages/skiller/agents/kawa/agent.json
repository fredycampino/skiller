{
  "llm": {
    "default_provider": "codex"
  },
  "loop": {
    "max_turns": 10,
    "max_tool_calls": 5
  },
  "tools": {
    "shell": {
      "workspace": ".",
      "allowlist_enabled": true,
      "allow_env_prefix": true,
      "allowed_commands": [
        "pwd",
        "ls",
        "find",
        "rg",
        "grep",
        "sed",
        "head",
        "tail",
        "sort",
        "wc",
        "nl",
        "cat",
        "git",
        "pytest",
        "ruff",
        "python",
        "python3",
        "skiller",
        "sleep",
        "echo",
        "date",
        "curl"
      ]
    },
    "files": {
      "read": [
        ".",
        "~/.skiller/settings/"
      ],
      "write": [
        "."
      ],
      "all": []
    }
  }
}
