{
  "loop": {
    "max_turns": 20,
    "max_tool_calls": 10
  },
  "tools": {
    "shell": {
      "allowed_paths": [
        ".",
        "./.venv/bin/skiller"
      ],
      "allowlist_enabled": true,
      "allow_env_prefix": true,
      "allowed_commands": [
        "pwd",
        "ls",
        "find",
        "rg",
        "grep",
        "head",
        "tail",
        "wc",
        "nl",
        "git",
        "pytest",
        "ruff",
        "python",
        "python3",
        "echo",
        "sleep",
        "skiller"
      ]
    },
    "files": {
      "read": [
        ".",
        "~/.skiller/settings/"
      ],
      "write": [
        "."
      ],
      "all": []
    }
  }
}
