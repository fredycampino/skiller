{
  "llm": {
    "default_provider": "minimax"
  },
  "providers": {
    "minimax": {
      "api_key_file": "~/.skiller/secrets/minimax_api_key",
      "model": "MiniMax-M2.5",
      "timeout_seconds": 30,
      "window_width_tokens": 1000000
    }
  },
  "loop": {
    "max_turns": 10,
    "max_tool_calls": 5
  },
  "tools": {
    "files": {
      "read": ["packages/skiller/tests/e2e-agent/files-tool/workspace"],
      "write": ["packages/skiller/tests/e2e-agent/files-tool/workspace"],
      "all": []
    }
  }
}
